# Normalize line endings to LF on commit, checkout as LF
* text=auto eol=lf

# Windows batch files must keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.zip binary
*.gz binary
*.tar binary
*.pdf binary
*.mp3 binary
*.mp4 binary
*.wav binary
*.ogg binary
*.webm binary
*.safetensors binary
*.gguf binary
*.bin binary
*.apk binary
